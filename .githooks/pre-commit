#!/usr/bin/env bash
# Pre-commit hook for residuum
# Enforces code quality before commits are created

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m' # No Color

echo -e "${YELLOW}Running pre-commit checks...${NC}"

# Detect staged file categories
STAGED_RS_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.rs$' || true)
STAGED_TOML_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.toml$' || true)
STAGED_WEB_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^web/src/.*\.(ts|svelte|js|css)$' || true)

HAS_RUST=false
HAS_WEB=false
[ -n "$STAGED_RS_FILES" ] || [ -n "$STAGED_TOML_FILES" ] && HAS_RUST=true
[ -n "$STAGED_WEB_FILES" ] && HAS_WEB=true

# Calculate total steps for progress display
RUST_STEPS=0
WEB_STEPS=0
$HAS_RUST && RUST_STEPS=4
$HAS_WEB && WEB_STEPS=3
TOTAL_STEPS=$((RUST_STEPS + WEB_STEPS))
STEP=0

# --- Rust checks ---
if $HAS_RUST; then
    STEP=$((STEP + 1))
    echo -e "\n${YELLOW}[$STEP/$TOTAL_STEPS] Auto-formatting Rust code...${NC}"
    cargo fmt > /dev/null 2>&1
    git add -u > /dev/null 2>&1
    echo -e "${GREEN}✓ Formatting applied${NC}"

    STEP=$((STEP + 1))
    echo -e "\n${YELLOW}[$STEP/$TOTAL_STEPS] Running clippy...${NC}"
    if ! OUTPUT=$(cargo clippy --all-targets -- -D warnings 2>&1); then
        echo "$OUTPUT"
        echo -e "${RED}ERROR: Clippy found issues.${NC}"
        exit 1
    fi
    echo -e "${GREEN}✓ Clippy OK${NC}"

    STEP=$((STEP + 1))
    echo -e "\n${YELLOW}[$STEP/$TOTAL_STEPS] Running cargo deny...${NC}"
    if ! OUTPUT=$(cargo deny check 2>&1); then
        echo "$OUTPUT"
        echo -e "${RED}ERROR: cargo deny found issues.${NC}"
        exit 1
    fi
    echo -e "${GREEN}✓ Cargo deny OK${NC}"

    STEP=$((STEP + 1))
    echo -e "\n${YELLOW}[$STEP/$TOTAL_STEPS] Running tests...${NC}"
    # Extract module names from staged .rs files (src/<module>/... or src/<module>.rs)
    CHANGED_MODULES=$(echo "$STAGED_RS_FILES" | sed -n 's|^src/\([^/]*\).*\.rs$|\1|p' | sort -u)
    if [ -n "$CHANGED_MODULES" ]; then
        TEST_FILTERS=""
        for mod in $CHANGED_MODULES; do
            # Strip .rs suffix for single-file modules
            mod="${mod%.rs}"
            TEST_FILTERS="$TEST_FILTERS ${mod}::"
        done
        FAIL=false
        for filter in $TEST_FILTERS; do
            if ! OUTPUT=$(cargo test --quiet "$filter" 2>&1); then
                echo "$OUTPUT"
                FAIL=true
            fi
        done
        if $FAIL; then
            echo -e "${RED}ERROR: Tests failed.${NC}"
            exit 1
        fi
    else
        if ! OUTPUT=$(cargo test --quiet 2>&1); then
            echo "$OUTPUT"
            echo -e "${RED}ERROR: Tests failed.${NC}"
            exit 1
        fi
    fi
    echo -e "${GREEN}✓ Tests OK${NC}"
else
    echo "No Rust or TOML files staged, skipping Rust checks."
fi

# --- Web checks ---
if $HAS_WEB; then
    STEP=$((STEP + 1))
    echo -e "\n${YELLOW}[$STEP/$TOTAL_STEPS] Auto-formatting web code...${NC}"
    (cd web && npm run format > /dev/null 2>&1)
    git add -u > /dev/null 2>&1
    echo -e "${GREEN}✓ Formatting applied${NC}"

    STEP=$((STEP + 1))
    echo -e "\n${YELLOW}[$STEP/$TOTAL_STEPS] Linting web code...${NC}"
    if ! OUTPUT=$(cd web && npm run lint 2>&1); then
        echo "$OUTPUT"
        echo -e "${RED}ERROR: ESLint found issues.${NC}"
        exit 1
    fi
    echo -e "${GREEN}✓ Lint OK${NC}"

    STEP=$((STEP + 1))
    echo -e "\n${YELLOW}[$STEP/$TOTAL_STEPS] Type-checking web code...${NC}"
    if ! OUTPUT=$(cd web && npm run check 2>&1); then
        echo "$OUTPUT"
        echo -e "${RED}ERROR: svelte-check found issues.${NC}"
        exit 1
    fi
    echo -e "${GREEN}✓ Type check OK${NC}"
else
    [ -z "$STAGED_WEB_FILES" ] && echo "No web files staged, skipping web checks."
fi

# Check for common issues in Rust files only
if [ -n "$STAGED_RS_FILES" ]; then
    echo -e "\n${YELLOW}Checking for common issues...${NC}"

    # Check for debug prints left in code
    if git diff --cached --diff-filter=ACM -- '*.rs' | grep -E '^\+.*\bdbg!\(' > /dev/null 2>&1; then
        echo -e "${RED}WARNING: Found dbg!() macro in staged changes.${NC}"
        echo "Remove debug macros before committing."
        exit 1
    fi

    # Check for FIXME/XXX comments (warn but don't block)
    if git diff --cached --diff-filter=ACM -- '*.rs' | grep -E '^\+.*(FIXME|XXX)' > /dev/null 2>&1; then
        echo -e "${YELLOW}NOTE: Found FIXME/XXX comments in staged changes.${NC}"
    fi
fi

echo -e "\n${GREEN}All pre-commit checks passed!${NC}"
